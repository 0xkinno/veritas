# ── Wallet (never commit the real .env) ──
PRIVATE_KEY=your_wallet_private_key_here

# ── Mantle ──
MANTLE_TESTNET_RPC=https://rpc.sepolia.mantle.xyz
MANTLE_MAINNET_RPC=https://rpc.mantle.xyz
MANTLE_EXPLORER_API_KEY=your_explorer_key

# ── AI ──
GROQ_API_KEY=your_groq_api_key

# ── Bybit ──
BYBIT_API_KEY=your_bybit_api_key
BYBIT_API_SECRET=your_bybit_api_secret
BYBIT_TESTNET=true

# ── Contracts (filled by deploy.js automatically) ──
IDENTITY_REGISTRY=0x...
REPUTATION_REGISTRY=0x...
VALIDATION_REGISTRY=0x...

# ── Vite (frontend reads these) ──
VITE_IDENTITY_REGISTRY=0x..
VITE_REPUTATION_REGISTRY=0x..
VITE_VALIDATION_REGISTRY=0x...
VITE_CHAIN_ID=5003